<?xml version="1.0" encoding="utf-8"?>
<robot name="trailerbot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="base_footprint"/>

    <link name="base_link">
        <visual>
            <geometry><box size="1.0 0.5 0.25"/></geometry>
            <material name="blue"><color rgba="0 0 1 1"/></material>
        </visual>
        <collision>
            <geometry><box size="1.0 0.5 0.25"/></geometry>
        </collision>
        <inertial>
            <mass value="30.0"/>
            <inertia ixx="0.104" ixy="0.0" ixz="0.0" iyy="0.217" iyz="0.0" izz="0.260"/>
        </inertial>
    </link>

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="left_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><cylinder length="0.1" radius="0.1"/></geometry>
            <material name="red"><color rgba="1 0 0 1"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><cylinder length="0.1" radius="0.1"/></geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.00033" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.00033"/>
        </inertial>
    </link>

    <link name="right_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><cylinder length="0.1" radius="0.1"/></geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><cylinder length="0.1" radius="0.1"/></geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.00033" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.00033"/>
        </inertial>
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="-0.25 0.25 -0.125" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="-0.25 -0.25 -0.125" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <link name="caster_wheel">
        <visual>
            <geometry><sphere radius="0.1"/></geometry>
            <material name="red"/>
        </visual>
        <collision>
            <geometry><sphere radius="0.1"/></geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0002"/>
        </inertial>
    </link>

    <joint name="caster_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel"/>
        <origin xyz="0.35 0 -0.125" rpy="0 0 0"/>
    </joint>

    <link name="drawbar_link">
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0106" iyz="0.0" izz="0.0106"/>
        </inertial>
        <visual>
            <geometry><box size="0.5 0.08 0.08"/></geometry>
            <material name="dark_gray"><color rgba="0.2 0.2 0.2 1.0"/></material>
        </visual>
        <collision>
            <geometry><box size="0.5 0.08 0.08"/></geometry>
        </collision>
    </link>

    <link name="trailer_link">
        <visual>
            <geometry><box size="0.5 0.1 0.1"/></geometry>
            <material name="red"/>
        </visual>
        <collision>
            <geometry><box size="0.5 0.1 0.1"/></geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <inertia ixx="0.0016" ixy="0.0" ixz="0.0" iyy="0.0216" iyz="0.0" izz="0.0216"/>
        </inertial>
    </link>

    <joint name="trailer_joint" type="fixed">
        <parent link="base_link"/>
        <child link="trailer_link"/>
        <origin xyz="-0.5 0 0" rpy="0 0 0"/>
    </joint>

    <link name="pivot_marker_link">
        <visual>
            <geometry><sphere radius="0.08"/></geometry>
            <material name="yellow"><color rgba="1.0 0.9 0.1 1.0"/></material>
        </visual>
        <collision>
            <geometry><sphere radius="0.08"/></geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.00025" ixy="0.0" ixz="0.0" iyy="0.00025" iyz="0.0" izz="0.00025"/>
        </inertial>
    </link>

    <joint name="pivot_marker_joint" type="fixed">
        <parent link="trailer_link"/>
        <child link="pivot_marker_link"/>
        <origin xyz="-0.25 0 0.0" rpy="0 0 0"/>
    </joint>

    <joint name="pivot_marker_drawbar_joint" type="revolute">
        <parent link="pivot_marker_link"/>
        <child link="drawbar_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
    </joint>

    <link name="container">
        <visual>
            <geometry><box size="3.0 1.0 1.0"/></geometry>
            <material name="green"><color rgba="0 1 0 1"/></material>
        </visual>
        <collision>
            <geometry><box size="3.0 1.0 1.0"/></geometry>
        </collision>
        <inertial>
            <mass value="5.0"/>
            <inertia ixx="1.667" ixy="0.0" ixz="0.0" iyy="8.333" iyz="0.0" izz="8.333"/>
        </inertial>
    </link>

    <joint name="container_joint" type="fixed">
        <parent link="drawbar_link"/>
        <child link="container"/>
        <origin xyz="-1.75 0 0.375" rpy="0 0 0"/>
    </joint>

    <link name="container_rear_left_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><cylinder length="0.1" radius="0.1"/></geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><cylinder length="0.1" radius="0.1"/></geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.00033" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.00033"/>
        </inertial>
    </link>

    <link name="container_rear_right_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><cylinder length="0.1" radius="0.1"/></geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry><cylinder length="0.1" radius="0.1"/></geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.00033" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.00033"/>
        </inertial>
    </link>

    <link name="container_front_left_wheel">
        <visual>
            <geometry><sphere radius="0.1"/></geometry>
            <material name="red"/>
        </visual>
        <collision>
            <geometry><sphere radius="0.1"/></geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.0004" ixy="0.0" ixz="0.0" iyy="0.0004" iyz="0.0" izz="0.0004"/>
        </inertial>
    </link>

    <link name="container_front_right_wheel">
        <visual>
            <geometry><sphere radius="0.1"/></geometry>
            <material name="red"/>
        </visual>
        <collision>
            <geometry><sphere radius="0.1"/></geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.0004" ixy="0.0" ixz="0.0" iyy="0.0004" iyz="0.0" izz="0.0004"/>
        </inertial>
    </link>

    <joint name="container_rear_left_wheel_joint" type="continuous">
        <parent link="container"/>
        <child link="container_rear_left_wheel"/>
        <origin xyz="-1.0 0.5 -0.5" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="container_rear_right_wheel_joint" type="continuous">
        <parent link="container"/>
        <child link="container_rear_right_wheel"/>
        <origin xyz="-1.0 -0.5 -0.5" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="container_front_left_wheel_joint" type="fixed">
        <parent link="container"/>
        <child link="container_front_left_wheel"/>
        <origin xyz="1.0 0.5 -0.5" rpy="0 0 0"/>
    </joint>

    <joint name="container_front_right_wheel_joint" type="fixed">
        <parent link="container"/>
        <child link="container_front_right_wheel"/>
        <origin xyz="1.0 -0.5 -0.5" rpy="0 0 0"/>
    </joint>

    <gazebo reference="caster_wheel"><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>
    <gazebo reference="container_front_left_wheel"><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>
    <gazebo reference="container_front_right_wheel"><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>
    <gazebo reference="container_rear_left_wheel"><mu1>0.05</mu1><mu2>0.05</mu2></gazebo>
    <gazebo reference="container_rear_right_wheel"><mu1>0.05</mu1><mu2>0.05</mu2></gazebo>

    <gazebo>
        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>left_wheel_joint</left_joint>
            <right_joint>right_wheel_joint</right_joint>
            <wheel_separation>0.5</wheel_separation>
            <wheel_radius>0.1</wheel_radius>
            <topic>cmd_vel</topic>
            <odom_topic>odom</odom_topic>
            <tf_topic>tf</tf_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
            <joint_name>pivot_marker_drawbar_joint</joint_name>
            <joint_name>left_wheel_joint</joint_name>
            <joint_name>right_wheel_joint</joint_name>
            <joint_name>container_rear_left_wheel_joint</joint_name>
            <joint_name>container_rear_right_wheel_joint</joint_name>
        </plugin>
    </gazebo>
</robot>